# --- Supabase ---
# Dashboard Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...

# --- Database (Supabase Postgres) ---
# Dashboard Supabase > Project Settings > Database > Connection string
#
# DATABASE_URL  -> gunakan "Connection pooling" (Transaction mode, port 6543)
#                  WAJIB tambahkan ?pgbouncer=true
# DIRECT_URL    -> gunakan "Direct connection" (port 5432), dipakai prisma migrate / db push
#
# Ganti [PASSWORD] dengan password database Anda (di-set saat membuat project).
DATABASE_URL="postgresql://postgres.hxmilohhyfucaivemtpu:KMPk8jUqRxIsOQGK@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.xxx:[PASSWORD]@aws-0-xxx.pooler.supabase.com:5432/postgres"
